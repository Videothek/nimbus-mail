{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Nimbus main window and any popped-out standalone mail windows (#104).",
  "windows": ["main", "mail-*"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-close",
    "notification:default",
    "dialog:default"
  ]
}
